# Copy to .env and adjust for your environment.
#
# Public URL the app is reached at. Required for SvelteKit's CSRF check
# to match the browser's Origin header. Override on production with the
# actual public URL, e.g. https://gritshot.example.com
BASE_URL=http://127.0.0.1:3000

# Random, long, secret string. Used by Better Auth to sign session cookies
# and magic-link tokens. Generate with e.g. `openssl rand -base64 48`.
AUTH_SECRET=change-me!!!

# SQLite database location. Inside the container this should live on a
# named volume so users and sessions survive container recreation.
DB_PATH=/data/dahamm.db

# Admin bootstrap. On every container start, this user is upserted into
# the user table and its isAdmin flag is forced to true. Other fields
# are left untouched. Without these two values, nobody can sign in.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME= Admin

# SMTP (Hetzner or similar) for sending magic-link emails in production.
# Required in production; ignored locally (the dev server logs the link
# to the console instead of sending mail).
SMTP_HOST=mail.your-server.de
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=